{
  "schemaVersion": "2026-03-31",
  "title": "HoopsClips clip annotation schema",
  "type": "object",
  "required": [
    "clipId",
    "sourceDomain",
    "sourceKind",
    "eventFamily",
    "outcome",
    "shotSubtype",
    "ballVisible",
    "hoopVisible",
    "ballNearRim",
    "ballThroughHoopLikelihood",
    "possessionChangeLikelihood",
    "transitionLikelihood",
    "teacherConfidence",
    "humanVerified",
    "reviewerNotes",
    "rawRuntimeOutputs",
    "rawTeacherOutputs",
    "schemaVersion"
  ],
  "properties": {
    "clipId": { "type": "string" },
    "sourceDomain": { "type": "string" },
    "sourceKind": { "type": "string" },
    "eventFamily": { "type": "string" },
    "outcome": { "type": "string" },
    "shotSubtype": { "type": ["string", "null"] },
    "ballVisible": { "type": "boolean" },
    "hoopVisible": { "type": "boolean" },
    "ballNearRim": { "type": "number" },
    "ballThroughHoopLikelihood": { "type": "number" },
    "possessionChangeLikelihood": { "type": "number" },
    "transitionLikelihood": { "type": "number" },
    "teacherConfidence": { "type": "number" },
    "humanVerified": { "type": "boolean" },
    "reviewerNotes": { "type": "string" },
    "rawRuntimeOutputs": { "type": "object" },
    "rawTeacherOutputs": { "type": "object" },
    "schemaVersion": { "type": "string" }
  }
}
