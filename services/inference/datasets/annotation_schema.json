{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rork.hoopshighlights.ai/schemas/annotation-schema.json",
  "schemaVersion": "2026-03-30",
  "title": "HoopsClips Clip Annotation",
  "description": "Canonical annotation schema for gold, silver, and disagreement-queue basketball clips.",
  "migrationNotes": "Older duplicate schema filenames were retired in phase3c1. Phase4 adds optional event-localization fields and old rows continue to load with null defaults when those fields are absent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "clipId",
    "sourceDomain",
    "schemaVersion",
    "eventFamily",
    "outcome",
    "shotSubtype",
    "ballVisible",
    "hoopVisible",
    "ballNearRim",
    "ballThroughHoopLikelihood",
    "possessionChangeLikelihood",
    "transitionLikelihood",
    "teacherConfidence",
    "humanVerified",
    "reviewerNotes",
    "rawRuntimeOutputs",
    "rawTeacherOutputs"
  ],
  "properties": {
    "clipId": { "type": "string", "minLength": 1 },
    "sourceDomain": { "type": "string", "minLength": 1 },
    "sourceRef": {
      "type": ["string", "null"],
      "description": "Optional original clip reference. Can be a local relative path, absolute path, URL, or r2:// reference."
    },
    "schemaVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version attached when the row was written. Defaults to the current canonical version if absent."
    },
    "eventFamily": {
      "type": "string",
      "enum": ["shot_attempt", "turnover", "defensive_event", "transition", "other"]
    },
    "outcome": {
      "type": "string",
      "enum": ["made", "missed", "blocked", "uncertain"]
    },
    "shotSubtype": {
      "type": ["string", "null"],
      "enum": ["dunk", "layup", "jumper", "three", "putback", "unknown", null]
    },
    "ballVisible": { "type": "boolean" },
    "hoopVisible": { "type": "boolean" },
    "ballNearRim": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
    "ballThroughHoopLikelihood": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
    "possessionChangeLikelihood": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
    "transitionLikelihood": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
    "teacherConfidence": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 },
    "humanVerified": { "type": "boolean" },
    "reviewerNotes": { "type": "string" },
    "eventStart": { "type": ["number", "null"], "minimum": 0.0 },
    "eventCenter": { "type": ["number", "null"], "minimum": 0.0 },
    "eventEnd": { "type": ["number", "null"], "minimum": 0.0 },
    "shotReleaseTime": { "type": ["number", "null"], "minimum": 0.0 },
    "ballNearRimTime": { "type": ["number", "null"], "minimum": 0.0 },
    "ballThroughHoopTime": { "type": ["number", "null"], "minimum": 0.0 },
    "possessionChangeTime": { "type": ["number", "null"], "minimum": 0.0 },
    "transitionStartTime": { "type": ["number", "null"], "minimum": 0.0 },
    "rawRuntimeOutputs": { "type": ["object", "null"] },
    "rawTeacherOutputs": { "type": ["object", "null"] }
  }
}
