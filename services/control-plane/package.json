{
  "name": "hoopsclips-control-plane",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging --keep-vars",
    "deploy:staging:dry-run": "wrangler deploy --env staging --dry-run",
    "deployments:staging": "wrangler deployments list --env staging",
    "rollback:staging": "wrangler rollback --env staging --yes",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cf:typegen": "wrangler types"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.94.0"
  }
}
